{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "krkr2",
  "version-string": "1.5.0",
  "dependencies": [
    "7zip",
    {
      "name": "argparse",
      "platform": "linux | windows | osx"
    },
    "boost-iostreams",
    {
      "name": "boost-locale",
      "default-features": false
    },
    "boost-phoenix",
    "boost-spirit",
    "fmt",
    "libarchive",
    "lz4",
    "oniguruma",
    {
      "name": "sdl2",
      "default-features": false
    },
    "spdlog",
    "uchardet",
    "unrar",
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    "zstd",
    "zlib",
    "minizip-ng"
  ]
}
